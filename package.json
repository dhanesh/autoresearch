{
  "name": "autoresearch",
  "version": "1.0.0",
  "private": true,
  "description": "Autonomous codebase improvement loop inspired by Karpathy's autoresearch",
  "type": "module",
  "scripts": {
    "install:plugin": "bash install/install.sh",
    "uninstall:plugin": "bash install/uninstall.sh",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/dhanesh/autoresearch"
  },
  "license": "MIT",
  "keywords": [
    "autoresearch",
    "claude-code",
    "plugin",
    "codebase-improvement",
    "iterative-optimization"
  ],
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@vitest/coverage-v8": "^4.1.1",
    "bun-types": "^1.3.11",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1"
  },
  "dependencies": {
    "zod": "^4.3.6"
  }
}
